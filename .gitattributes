# Auto-detect text files and normalize line endings, ensuring CRLF on checkout and in archives
* text=auto eol=crlf

# Batch files must always use CRLF line endings
*.bat text eol=crlf
*.cmd text eol=crlf

# Python, markdown, json and config files
*.py text
*.md text
*.json text
*.gitignore text

# Denote binary files to prevent Git from converting their line endings
*.xlsx binary
*.docx binary
*.png binary
*.jpg binary
*.ico binary

.gitattributes export-ignore
.gitignore export-ignore